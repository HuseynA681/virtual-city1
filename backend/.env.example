PORT=5000
DB_TYPE=mysql

# For Render/production, set these in the Render Environment tab.
# Do not rely on backend/.env in production; .env is intentionally not deployed.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=virtual_city

# Optional alternative:
# MYSQL_URL=mysql://user:password@host:3306/database

# Shared hosting usually already created the database, so leave this false on Render.
MYSQL_CREATE_DATABASE=false

JWT_SECRET=your-super-secret-key-here-12345-change-in-production
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
